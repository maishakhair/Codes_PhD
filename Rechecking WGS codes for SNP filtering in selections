read_sheet_safely <- function(file_path, sheet_name) {
  tryCatch({
    # Read without column names first to avoid issues
    data <- readxl::read_excel(file_path, sheet = sheet_name, col_names = FALSE, skip = 1)
    
    # Check if we have at least 2 columns
    if (ncol(data) >= 2) {
      result <- data.frame(
        gene_ID = as.character(data[[1]]),
        SNP = as.character(data[[2]]),
        stringsAsFactors = FALSE
      )
      # Remove NA rows
      result <- result[!is.na(result$gene_ID) & !is.na(result$SNP), ]
      return(result)
    } else {
      cat("  Warning: Sheet", sheet_name, "has less than 2 columns\n")
      return(data.frame(gene_ID = character(), SNP = character(), stringsAsFactors = FALSE))
    }
  }, error = function(e) {
    cat("  Error reading sheet:", sheet_name, "-", e$message, "\n")
    return(data.frame(gene_ID = character(), SNP = character(), stringsAsFactors = FALSE))
  })
}

