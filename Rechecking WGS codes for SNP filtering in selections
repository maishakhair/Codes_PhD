# Step 3: Function to filter parent SNPs
filter_parent_snps <- function(sheet_name, file_path) {
  data <- read_sheet_safely(file_path, sheet_name)
  
  if (nrow(data) == 0) {
    return(data)
  }
  
  # Create key for comparison
  data$key <- paste0(data$gene_ID, data$SNP)
  parent_key <- paste0(parent_snps$gene_ID, parent_snps$SNP)
  
  # Filter out parent SNPs
  filtered_data <- data[!data$key %in% parent_key, c("gene_ID", "SNP")]
  
  return(filtered_data)
}

