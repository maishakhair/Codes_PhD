# Step 6: Filter High-Dose SNPs by Removing Low-Dose SNPs
filter_high_doses <- function(high_sheet, low_dose_data, file_path) {
  high_dose <- filter_parent_snps(high_sheet, file_path)
  
  if (nrow(high_dose) == 0 || nrow(low_dose_data) == 0) {
    return(high_dose)
  }
  
  # Create keys for comparison
  high_dose$key <- paste0(high_dose$gene_ID, high_dose$SNP)
  low_key <- paste0(low_dose_data$gene_ID, low_dose_data$SNP)
  
  # Filter
  filtered_high <- high_dose[!high_dose$key %in% low_key, c("gene_ID", "SNP")]
  
  return(filtered_high)
}

